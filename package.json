{
	"name": "github-action-repo-sync",
	"version": "4.0.1",
	"private": true,
	"description": "GitHub Action to detect and sync project metadata to GitHub.",
	"keywords": [
		"github-action",
		"action",
		"repo",
		"project",
		"metadata"
	],
	"homepage": "https://github.com/kitschpatrol/github-action-repo-sync",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/github-action-repo-sync.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"scripts": {
		"build": "ncc build src/index.ts -o dist -t",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"test": "vitest",
		"updatetag": "git tag -d v4 && git push origin :v4 && git tag -a v4 -m '' && git push origin v4"
	},
	"devDependencies": {
		"@actions/core": "^3.0.0",
		"@actions/github": "^9.0.0",
		"@kitschpatrol/codemeta": "^0.3.2",
		"@kitschpatrol/shared-config": "^6.0.1",
		"@octokit/rest": "^22.0.1",
		"@types/node": "~22.17.2",
		"@vercel/ncc": "^0.38.4",
		"typescript": "~5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": ">=22.17.0"
	}
}
